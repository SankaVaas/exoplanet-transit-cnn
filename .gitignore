# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# Environments
.venv/
venv/
env/
.env

# Data (large / regenerable — never commit raw astronomical data)
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Model artifacts (large binaries — track via releases or DVC, not git)
models/checkpoints/*
!models/checkpoints/.gitkeep
*.h5
*.pt
*.pth
*.ckpt
*.onnx

# Outputs
outputs/logs/*
!outputs/logs/.gitkeep

# Jupyter
*.ipynb_checkpoints

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Colab
*.ipynb.bak

# Distribution / packaging
build/
dist/
*.egg-info/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Secrets
*.env
credentials.json
kaggle.json
